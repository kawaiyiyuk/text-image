PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000

# 部署在 Nginx/Caddy 等反向代理之后时设为 1（本地直连调试不要开）
# TRUST_PROXY=1

# 登录会话有效期（毫秒），默认 7 天。账号密码在 server/src/config.js 中配置。
# AUTH_TOKEN_TTL_MS=604800000

# 没有真实模型 Key 时保持 true，可先跑通网页流程。
MODEL_MOCK=true

# 真实模型配置。
# 多数聚合网关（如 aiproxy 类）的 gpt-image-2 / nano-banana 走 POST /v1/chat/completions（JSON），返回里带图片 URL/markdown。
# 仅当某模型不在 MODEL_IMAGE_VIA_CHAT_MODELS 里时：无参考图用 images/generations，有参考图用 images/edits（multipart，易触发上游 413）。
MODEL_PROVIDER=openai
MODEL_API_BASE=https://proaiapi.tech/v1
MODEL_API_KEY=
# 默认选中的生图模型（与同一网关下的 model 名称一致即可，无需改 KEY / BASE）
MODEL_IMAGE_MODEL=gpt-image-2
# 可选模型列表（逗号分隔）。不配置时默认可选：gpt-image-2、nano-banana
# MODEL_IMAGE_MODEL_OPTIONS=gpt-image-2,nano-banana
# 走 chat/completions 的模型（逗号分隔）。不设时默认：nano-banana,gpt-image-2（图生图与官网 OpenAI 的 images/edits 不同路，可避免 multipart 413）
# MODEL_IMAGE_VIA_CHAT_MODELS=nano-banana,gpt-image-2
# 若网关示例要求带 group 字段：MODEL_CHAT_GROUP=default
# MODEL_CHAT_GROUP=default
# chat/edits 前参考图过大会触发 413；超过阈值会缩放/转 JPEG（两路共用）
# MODEL_CHAT_REF_MAX_RAW_BYTES=512000
# MODEL_CHAT_REF_MAX_EDGE=1536
# MODEL_CHAT_REF_JPEG_QUALITY=82
MODEL_IMAGE_N=1
MODEL_RESPONSE_FORMAT=url
MODEL_TIMEOUT_MS=300000

# DeepSeek 官方 API 是文本对话接口，不直接生成图片。
# 开启后用于优化生图提示词，再调用上面的图片生成接口。
DEEPSEEK_ENABLED=false
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=60000
